# Python
__pycache__/
*.py[cod]
.mypy_cache/
.pytest_cache/
.venv/
venv/

# Editors
.vscode/

# Data / generated outputs (do not upload)
datasets/
graphs/
*.duckdb
*.tsv
*.parquet
*.zst
*.tar
*.tar.*
*.gz
*.bz2
*.xz
*.zip
*.obj

# Rust/Cargo build outputs
target/
**/target/

# ISPG generated outputs (plans are regenerated by the optimizer)
ispg/**/query_plan/
ispg/**/query_plan_duckdb/
*.plan
**/plan_generation_time_ms.csv

# Local-only source overrides (requires the LDBC SF1 dataset to run)
ispg/ldbc/ldbc_ic_compiler.py

# IMDB large artifacts (datasets, catalogs, generated filters/plans) are kept
# out of the repo; the IMDB optimizer/compiler sources are committed below.
ispg/imdb/**
!ispg/imdb/.gitkeep
!ispg/imdb/__init__.py
!ispg/imdb/job/
!ispg/imdb/job/__init__.py
!ispg/imdb/job/job_query_optimizer.py
!ispg/imdb/job/imdb_job_query_compiler.py

# Misc
.DS_Store
*.log
tmp/

# Generated CSV/TSV (e.g. plan-timing reports)
*.csv

# ---------------------------------------------------------------------------
# Required LDBC run inputs — these MUST be committed so the LDBC optimizer
# works from a fresh clone. They are exceptions to the broad ignores above.
# query_filters/ and query_pattern/ are plain JSON and not ignored anywhere.
# ---------------------------------------------------------------------------
# Bincode catalogs are large/binary and ignored by default, except the
# pre-built LDBC small catalog used by the committed run scripts.
*.bincode
!catalogs/
!catalogs/ldbc_small/
!catalogs/ldbc_small/glogs/
!catalogs/ldbc_small/glogs/ldbc_sf0.003.bincode
